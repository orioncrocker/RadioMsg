<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <PreferenceScreen
        android:key="simpleexpertPS"
        android:title="USAGE MODES">
        <ListPreference
            android:defaultValue="0"
            android:entries="@array/usagemodes"
            android:entryValues="@array/usage_modes"
            android:key="USAGEMODE"
            android:summary="Selects usage specific features"
            android:title="Usage Mode" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="EXPERTMODE"
            android:summary="Opens complex functions and settings"
            android:title="Expert Mode" />
    </PreferenceScreen>

    <PreferenceScreen
        android:dependency="EXPERTMODE"
        android:key="modelistPS"
        android:title="MODES">
        <ListPreference
            android:defaultValue="MFSK16"
            android:key="HF-Poor"
            android:title="Mode list for HF Poor conditions" />
        <ListPreference
            android:defaultValue="MFSK32"
            android:key="HF-Good"
            android:title="Mode list for HF Good conditions" />
        <ListPreference
            android:defaultValue="MFSK64"
            android:key="HF-Fast"
            android:title="Mode list for HF Fast Transfers" />
        <ListPreference
            android:defaultValue="MFSK32"
            android:key="UHF-Poor"
            android:title="Mode list for UHF Poor conditions" />
        <ListPreference
            android:defaultValue="PSK500R"
            android:key="UHF-Good"
            android:title="Mode list for UHF Good conditions" />
        <ListPreference
            android:defaultValue="PSK500RX2"
            android:key="UHF-Fast"
            android:title="Mode list for UHF Fast Transfers" />
    </PreferenceScreen>

    <PreferenceScreen
        android:key="quickMessagesPS"
        android:title="QUICK MESSAGES">
