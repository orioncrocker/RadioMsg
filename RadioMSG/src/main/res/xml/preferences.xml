        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS4"
            android:title="Message 4" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS5"
            android:title="Message 5" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS6"
            android:title="Message 6" />
