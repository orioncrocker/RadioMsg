            android:defaultValue=""
            android:key="QUICKSMS7"
            android:title="Message 7" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS8"
            android:title="Message 8" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS9"
            android:title="Message 9" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS10"
            android:title="Message 10" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS11"
            android:title="Message 11" />
        <EditTextPreference
            android:defaultValue=""
