            android:title="Message 13" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS14"
            android:title="Message 14" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS15"
            android:title="Message 15" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS16"
            android:title="Message 16" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS17"
            android:title="Message 17" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS18"
            android:title="Message 18" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS19"
            android:title="Message 19" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS20"
            android:title="Message 20" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS21"
            android:title="Message 21" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS22"
            android:title="Message 22" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS23"
            android:title="Message 23" />
        <EditTextPreference
            android:defaultValue=""
            android:key="QUICKSMS24"
