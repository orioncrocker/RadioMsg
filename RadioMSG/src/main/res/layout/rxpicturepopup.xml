<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/html_popup"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1.00"
    android:background="#F0000000">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:weightSum="1">

        <LinearLayout
            android:id="@+id/FrameLayout2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.08"
            android:orientation="horizontal"
            android:weightSum="1">

            <Button
                android:id="@+id/button_close"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:text="Return"/>

            <Button
                android:id="@+id/button_slant_left"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:enabled="true"
                android:text="Slant     Left"/>

            <Button
                android:id="@+id/button_slant_right"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:enabled="true"
                android:text="Slant Right"/>

            <Button
                android:id="@+id/button_save_again"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:enabled="true"
                android:text="Save Again"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/FrameLayout2A"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.08"
            android:orientation="horizontal"
            android:weightSum="1">

            <Button
                android:id="@+id/button_shift_left"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:text="Shift L"/>

            <Button
                android:id="@+id/button_shift_right"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:enabled="true"
                android:text="Shift R"/>

            <Button
                android:id="@+id/button_descramble"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:enabled="false"
                android:text="De-scramb."/>

            <Button
                android:id="@+id/button_revert"
                android:layout_width="87dp"
                android:layout_height="87dp"
                android:layout_gravity="fill_vertical"
                android:layout_weight="0.25"
                android:enabled="true"
                android:text="revert"/>

        </LinearLayout>


        <TextView
            android:id="@+id/logtext"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/imageView1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:minHeight="300dip"
            android:scaleType="fitCenter"/>
    </LinearLayout>
</ScrollView>


